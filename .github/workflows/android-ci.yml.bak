name: Android CI

on:
  push:
    branches: [ master ]
  pull_request:
    branches: [ master ]
  release:
    types: [published]

permissions:
  contents: write

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0 # 保持完整历史记录以便获取版本信息

      - name: Set up JDK 25
        uses: actions/setup-java@v4
        with:
          java-version: "25"
          distribution: "temurin"
          
      - name: Setup Gradle
        uses: gradle/actions/setup-gradle@v3
        
      - name: Gradle Cache
        uses: actions/cache@v3
        with:
          path: |
            ~/.gradle/caches
            ~/.gradle/wrapper
            ${{ github.workspace }}/.gradle
          key: ${{ runner.os }}-gradle-${{ hashFiles('**/build.gradle.kts', '**/settings.gradle.kts') }}
          restore-keys: |
            ${{ runner.os }}-gradle-
            
      - name: Decode Keystore
        env:
          ENCODED_STRING: ${{ secrets.SIGNING_KEY }}
        run: |
          echo $ENCODED_STRING | base64 -d > android/tag_keystore.p12

      # ================= 新增：批量注释 System.exit =================
      - name: Comment out System.exit in Java files
        run: |
          echo "开始检索并注释 System.exit..."
          find . -name "*.java" -exec sed -i -E 's/(System\.exit\s*\([^)]*\)\s*;?)/\/\/ \1/g' {} +
          echo "替换完成！"

      # ================= 修复：只精准修改 ChunkerBlockIdentifier.java =================
      - name: Fix ChunkerBlockIdentifier StringBuilder.isEmpty
        run: |
          echo "正在精准修复 ChunkerBlockIdentifier.java..."
          
          # 直接定位到这个特定的文件
          TARGET_FILE=$(find . -name "ChunkerBlockIdentifier.java" | head -n 1)
          
          if [ -n "$TARGET_FILE" ]; then
              echo "找到目标文件: $TARGET_FILE"
              # 仅在这个文件里，把 builder.isEmpty() 替换为 builder.length() > 0 的正向逻辑（或者 builder.length() == 0）
              # 这里的正则加上了 builder. 前缀，确保只动 StringBuilder
              sed -i -E 's/!builder\.isEmpty\(\)/builder.length() > 0/g' "$TARGET_FILE"
              sed -i -E 's/builder\.isEmpty\(\)/builder.length() == 0/g' "$TARGET_FILE"
              echo "修改完毕！"
          else
              echo "未找到 ChunkerBlockIdentifier.java 文件，请检查路径！"
              exit 1
          fi
      # =============================================================================
      
      - name: Build with Gradle
        run: ./gradlew assembleDebug

      - name: Get version info
        id: version
        shell: bash
        run: |
          echo "BUILD_VERSION=auto-build-$(date +%Y%m%d_%H%M%S)-${GITHUB_SHA:0:8}" >> $GITHUB_OUTPUT
          echo "TIMESTAMP=$(date +"%Y-%m-%d %H:%M:%S")" >> $GITHUB_OUTPUT

      - name: Create Draft Release
        if: github.event_name == 'push' && github.ref == 'refs/heads/master'
        uses: softprops/action-gh-release@v2 # 升级到 v2
        with:
          tag_name: ${{ steps.version.outputs.BUILD_VERSION }}
          name: "Auto Build ${{ steps.version.outputs.BUILD_VERSION }}"
          body: |
            ### 构建信息
            - 提交: `${{ github.sha }}`
            - 构建时间: `${{ steps.version.outputs.TIMESTAMP }}`
            
            **注意**: Release 包含 Release 和 Debug 两种 APK。
          draft: true
          files: |
            android/build/outputs/apk/debug/*.apk
            android/build/outputs/apk/release/*.apk
            android/build/outputs/mapping/release/mapping.txt
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          
      - name: Save Gradle cache
        if: ${{ success() }}
        uses: actions/cache@v3
        with:
          path: |
            ~/.gradle/caches
            ~/.gradle/wrapper
            ${{ github.workspace }}/.gradle
          key: ${{ runner.os }}-gradle-${{ hashFiles('**/build.gradle.kts', '**/settings.gradle.kts') }}