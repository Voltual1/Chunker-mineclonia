name: Wasmjs CI

on:
  push:
    branches: [ master ]
  pull_request:
    branches: [ master ]
  release:
    types: [published]

permissions:
  contents: write

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0 # 保持完整历史记录以便获取版本信息

      - name: Set up JDK 25
        uses: actions/setup-java@v4
        with:
          java-version: "25"
          distribution: "temurin"
          
      - name: Check Architecture
        run: uname -m
          
      - name: Set up Node.js (Pre-installed for KMP)
        uses: actions/setup-node@v4
        with:
          node-version: '24.10.0'          

      - name: Setup Gradle
        uses: gradle/actions/setup-gradle@v3
        
      - name: Gradle Cache
        uses: actions/cache@v3
        with:
          path: |
            ~/.gradle/caches
            ~/.gradle/wrapper
            ${{ github.workspace }}/.gradle
          key: ${{ runner.os }}-gradle-${{ hashFiles('**/build.gradle.kts', '**/settings.gradle.kts') }}
          restore-keys: |
            ${{ runner.os }}-gradle-
            
      - name: Decode Keystore
        env:
          ENCODED_STRING: ${{ secrets.SIGNING_KEY }}
        run: |
          echo $ENCODED_STRING | base64 -d > android/tag_keystore.p12

      - name: Build WasmJS Distribution
        run: ./gradlew :wasmjs:wasmJsBrowserDevelopmentDistribution
        env:
          KEYSTORE_PATH: tag_keystore.p12
          KEYSTORE_PASSWORD: ${{ secrets.KEYSTORE_PASSWORD }}
          KEY_ALIAS: ${{ secrets.KEY_ALIAS }}
          KEY_PASSWORD: ${{ secrets.KEY_PASSWORD }}          

      - name: Package WasmJS Outputs
        run: |
          mkdir -p "$GITHUB_WORKSPACE/build-artifacts"
          if [ -d "wasmjs/build/dist/wasmJs/productionExecutable" ]; then
            cd wasmjs/build/dist/wasmJs/productionExecutable
            zip -r "$GITHUB_WORKSPACE/build-artifacts/pyrolysis-wasm.zip" .
            cd -
          elif [ -d "wasmjs/build/dist/wasmJs/developmentExecutable" ]; then
            cd wasmjs/build/dist/wasmJs/developmentExecutable
            zip -r "$GITHUB_WORKSPACE/build-artifacts/pyrolysis-wasm.zip" .
            cd -
          else
            echo "Error: WasmJS distribution directory not found!"
            exit 1
          fi

      - name: Get version info
        id: version
        shell: bash
        run: |
          echo "BUILD_VERSION=auto-build-$(date +%Y%m%d_%H%M%S)-${GITHUB_SHA:0:8}" >> $GITHUB_OUTPUT
          echo "TIMESTAMP=$(date +"%Y-%m-%d %H:%M:%S")" >> $GITHUB_OUTPUT

      - name: Create Draft Release
        if: github.event_name == 'push' && github.ref == 'refs/heads/master'
        uses: softprops/action-gh-release@v2
        with:
          tag_name: ${{ steps.version.outputs.BUILD_VERSION }}
          name: "Auto Build ${{ steps.version.outputs.BUILD_VERSION }}"
          body: |
            ### 构建信息
            - 提交: `${{ github.sha }}`
            - 构建时间: `${{ steps.version.outputs.TIMESTAMP }}`
            
            **注意**: 这是一个自动生成的 WasmJS 生产/开发环境分发包。
          draft: true
          files: |
            build-artifacts/pyrolysis-wasm.zip
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

      - name: Save Gradle cache
        if: ${{ success() }}
        uses: actions/cache@v3
        with:
          path: |
            ~/.gradle/caches
            ~/.gradle/wrapper
            ${{ github.workspace }}/.gradle
          key: ${{ runner.os }}-gradle-${{ hashFiles('**/build.gradle.kts', '**/settings.gradle.kts') }}